---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLang, useTranslations } from "../i18n/utils";

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);
const homeHref = lang === "es" ? `${base}es/` : base;
---

<BaseLayout t={t} lang={lang} title="404 – Page Not Found">
  <section class="not-found technical-grid">
    <div class="not-found__container">
      <span class="not-found__code">404</span>
      <h1 class="not-found__title">
        {lang === "es" ? "Página no encontrada" : "Page Not Found"}
      </h1>
      <p class="not-found__desc">
        {
          lang === "es"
            ? "La ruta que buscas no existe o fue movida."
            : "The page you're looking for doesn't exist or has been moved."
        }
      </p>
      <a href={homeHref} class="not-found__btn">
        {lang === "es" ? "Volver al inicio" : "Back to Home"}
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - var(--header-height));
    background-color: var(--color-navy-900);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-8) var(--space-4);
  }

  .not-found__container {
    text-align: center;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .not-found__code {
    font-family: var(--font-mono);
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: var(--font-extrabold);
    color: var(--color-amber-500);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .not-found__title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: white;
  }

  .not-found__desc {
    font-size: var(--text-sm);
    color: var(--color-slate-400);
    line-height: 1.6;
  }

  .not-found__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background-color: var(--color-amber-500);
    color: var(--color-navy-950);
    font-weight: var(--font-bold);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-lg);
    transition: background-color var(--transition-base);
  }

  .not-found__btn:hover {
    background-color: var(--color-amber-600);
  }
</style>