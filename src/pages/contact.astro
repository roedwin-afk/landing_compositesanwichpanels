---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLang, useTranslations } from "../i18n/utils";
import { Phone, Mail, MapPin } from "lucide-astro";

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);

const coords = { lat: 19.4326, lng: -99.1948 };
---

<BaseLayout
    t={t}
    lang={lang}
    title={t.contact_page.title}
    description={t.contact_page.description}
>
    <section class="contact technical-grid">
        <div class="contact__radial"></div>
        <div class="container">
            <div class="contact__grid">
                <!-- Left column -->
                <div class="contact__info reveal">
                    <span class="contact__label">{t.contact_page.label}</span>
                    <h1 class="contact__title">{t.contact_page.title}</h1>
                    <p class="contact__desc">{t.contact_page.description}</p>

                    <div class="contact__details">
                        <a
                            href={`tel:${t.contact_page.phone}`}
                            class="contact-detail"
                        >
                            <span class="contact-detail__icon"
                                ><Phone size={18} /></span
                            >
                            <div>
                                <span class="contact-detail__label"
                                    >{t.contact_page.phone_label}</span
                                >
                                <span class="contact-detail__value"
                                    >{t.contact_page.phone}</span
                                >
                            </div>
                        </a>
                        <a
                            href={`mailto:${t.contact_page.email}`}
                            class="contact-detail"
                        >
                            <span class="contact-detail__icon"
                                ><Mail size={18} /></span
                            >
                            <div>
                                <span class="contact-detail__label"
                                    >{t.contact_page.email_label}</span
                                >
                                <span class="contact-detail__value"
                                    >{t.contact_page.email}</span
                                >
                            </div>
                        </a>
                        <div class="contact-detail">
                            <span class="contact-detail__icon"
                                ><MapPin size={18} /></span
                            >
                            <div>
                                <span class="contact-detail__label"
                                    >{t.contact_page.address_label}</span
                                >
                                <span class="contact-detail__value"
                                    >{t.contact_page.address}</span
                                >
                            </div>
                        </div>
                    </div>

                    <div id="contact-map" class="contact__map"></div>
                </div>

                <!-- Right column: form -->
                <div class="contact__form reveal reveal-delay-2">
                    <div class="form-card">
                        <form
                            action="https://forms.zohopublic.com/promaica/form/SolicituddeCotizacin/formperma/0G7mUvm1mHqTMr77oTQpng90acA6JYYKZtboiNDls70/htmlRecords/submit"
                            name="form"
                            id="contact-zoho-form"
                            method="POST"
                            accept-charset="UTF-8"
                            enctype="multipart/form-data"
                        >
                            <input
                                type="hidden"
                                name="zf_referrer_name"
                                value=""
                            />
                            <input
                                type="hidden"
                                name="zf_redirect_url"
                                value=""
                            />
                            <input type="hidden" name="zc_gad" value="" />

                            <div class="form-row form-row--2col">
                                <div class="form-group">
                                    <label class="form-label"
                                        >{
                                            lang === "es"
                                                ? "Nombre"
                                                : "First Name"
                                        } *</label
                                    >
                                    <input
                                        class="form-input"
                                        type="text"
                                        maxlength="255"
                                        name="Name_First"
                                        required
                                        placeholder={lang === "es"
                                            ? "Juan"
                                            : "John"}
                                    />
                                </div>
                                <div class="form-group">
                                    <label class="form-label"
                                        >{
                                            lang === "es"
                                                ? "Apellido"
                                                : "Last Name"
                                        } *</label
                                    >
                                    <input
                                        class="form-input"
                                        type="text"
                                        maxlength="255"
                                        name="Name_Last"
                                        required
                                        placeholder={lang === "es"
                                            ? "García"
                                            : "Smith"}
                                    />
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label"
                                    >{
                                        lang === "es"
                                            ? "Correo Electrónico"
                                            : "Email"
                                    } *</label
                                >
                                <input
                                    class="form-input"
                                    type="email"
                                    maxlength="255"
                                    name="Email"
                                    required
                                    placeholder={lang === "es"
                                        ? "tu@empresa.com"
                                        : "you@company.com"}
                                />
                            </div>

                            <div class="form-group">
                                <label class="form-label"
                                    >{
                                        lang === "es" ? "Teléfono" : "Phone"
                                    }</label
                                >
                                <input
                                    class="form-input"
                                    type="text"
                                    name="PhoneNumber_countrycode"
                                    maxlength="20"
                                    placeholder={lang === "es"
                                        ? "+52 55 0000 0000"
                                        : "+1 000 000 0000"}
                                />
                            </div>

                            <div class="form-group">
                                <label class="form-label"
                                    >{lang === "es" ? "Mensaje" : "Message"} *</label
                                >
                                <textarea
                                    class="form-input form-textarea"
                                    name="MultiLine"
                                    maxlength="65535"
                                    required
                                    placeholder={lang === "es"
                                        ? "Describe los requisitos de tu proyecto..."
                                        : "Describe your project requirements..."}
                                ></textarea>
                            </div>

                            <button type="submit" class="form-submit">
                                {
                                    lang === "es"
                                        ? "Enviar Solicitud"
                                        : "Send Inquiry"
                                }
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
></script>

<script is:inline>
    var mapInstance = null;

    function initMap() {
        var el = document.getElementById("contact-map");
        if (!el) return;
        if (typeof L === "undefined") {
            setTimeout(initMap, 100);
            return;
        }

        if (mapInstance) {
            mapInstance.remove();
            mapInstance = null;
            el.innerHTML = "";
        }

        mapInstance = L.map("contact-map", {
            center: [19.4326, -99.1948],
            zoom: 15,
            zoomControl: true,
            scrollWheelZoom: false,
        });

        L.tileLayer(
            "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
            {
                attribution:
                    '© <a href="https://carto.com/" style="color:#F59E0B">CARTO</a>',
                subdomains: "abcd",
                maxZoom: 20,
            },
        ).addTo(mapInstance);

        var icon = L.divIcon({
            className: "",
            html: '<div style="position:relative;width:20px;height:20px;display:flex;align-items:center;justify-content:center;"><div style="position:absolute;width:32px;height:32px;background:rgba(245,158,11,0.25);border-radius:50%;top:50%;left:50%;transform:translate(-50%,-50%);animation:mppulse 2s infinite;"></div><div style="width:14px;height:14px;background:#F59E0B;border:2px solid #fff;border-radius:50%;box-shadow:0 0 10px rgba(245,158,11,0.8);position:relative;z-index:1;"></div></div><style>@keyframes mppulse{0%{transform:translate(-50%,-50%) scale(1);opacity:0.6}100%{transform:translate(-50%,-50%) scale(2.2);opacity:0}}</style>',
            iconSize: [20, 20],
            iconAnchor: [10, 10],
        });

        L.marker([19.4326, -99.1948], { icon })
            .addTo(mapInstance)
            .bindPopup(
                '<div style="font-family:\'JetBrains Mono\',monospace;font-size:11px;color:#0B2B4A;line-height:1.6;padding:2px 4px;"><strong style="color:#F59E0B;font-size:12px">Composite Sandwich Panels</strong><br/>Masaryk 61, Int. 901<br/>Polanco V, 11560, CDMX</div>',
            )
            .openPopup();
    }

    initMap();
    document.addEventListener("astro:page-load", initMap);
</script>

<style>
    .contact {
        position: relative;
        min-height: calc(100vh - var(--header-height));
        background: linear-gradient(
            to bottom,
            var(--color-navy-950),
            var(--color-navy-900)
        );
        color: white;
        padding-block: var(--space-16) var(--space-20);
        overflow: hidden;
    }

    .contact__radial {
        position: absolute;
        inset: 0;
        background: radial-gradient(
            circle at top right,
            rgba(245, 158, 11, 0.07),
            transparent 50%
        );
        pointer-events: none;
    }

    .contact__grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-12);
        align-items: start;
    }

    @media (min-width: 1024px) {
        .contact__grid {
            grid-template-columns: 1fr 1fr;
            align-items: stretch;
        }
    }

    /* Left info */
    .contact__info {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .contact__label {
        display: inline-block;
        font-size: var(--text-xs);
        font-family: var(--font-mono);
        font-weight: var(--font-bold);
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--color-amber-400);
        background-color: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.2);
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-full);
        width: fit-content;
    }

    .contact__title {
        font-size: var(--text-3xl);
        font-weight: var(--font-extrabold);
        line-height: 1.15;
        letter-spacing: -0.02em;
        color: white;
    }

    @media (min-width: 640px) {
        .contact__title {
            font-size: var(--text-4xl);
        }
    }

    .contact__desc {
        font-size: var(--text-base);
        color: var(--color-slate-300);
        font-weight: var(--font-light);
        line-height: 1.7;
    }

    /* Details */
    .contact__details {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .contact-detail {
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
        transition: opacity var(--transition-base);
    }

    a.contact-detail:hover {
        opacity: 0.8;
    }

    .contact-detail__icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        background-color: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: var(--radius-lg);
        color: var(--color-amber-400);
        flex-shrink: 0;
    }

    .contact-detail__label {
        display: block;
        font-size: 0.65rem;
        font-family: var(--font-mono);
        color: var(--color-slate-400);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: var(--space-1);
    }

    .contact-detail__value {
        display: block;
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: white;
        line-height: 1.5;
    }

    /* Map */
    .contact__map {
        flex: 1;
        min-height: 260px;
        border-radius: var(--radius-xl);
        overflow: hidden;
        border: 1px solid rgba(74, 106, 138, 0.3);
        box-shadow: var(--shadow-lg);
    }

    .contact__form {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .form-card {
        flex: 1;
    }

    /* Form card */
    .form-card {
        background-color: var(--color-navy-800);
        border: 1px solid rgba(74, 106, 138, 0.4);
        border-radius: var(--radius-2xl);
        padding: var(--space-8);
    }

    .form-row {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    @media (min-width: 480px) {
        .form-row--2col {
            flex-direction: row;
        }
        .form-row--2col .form-group {
            flex: 1;
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        margin-bottom: var(--space-4);
    }

    .form-label {
        font-size: var(--text-xs);
        font-family: var(--font-mono);
        font-weight: var(--font-bold);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-slate-400);
    }

    .form-input {
        width: 100%;
        background-color: var(--color-navy-900);
        border: 1px solid var(--color-steel-700);
        border-radius: var(--radius-lg);
        padding: var(--space-3) var(--space-4);
        font-size: var(--text-sm);
        color: white;
        transition:
            border-color var(--transition-base),
            box-shadow var(--transition-base);
        outline: none;
    }

    .form-input::placeholder {
        color: var(--color-slate-600);
    }

    .form-input:focus {
        border-color: var(--color-amber-500);
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.15);
    }

    .form-textarea {
        min-height: 140px;
        resize: vertical;
        font-family: var(--font-sans);
        line-height: 1.6;
    }

    .form-submit {
        width: 100%;
        background: linear-gradient(
            to right,
            var(--color-amber-500),
            var(--color-orange-500)
        );
        color: var(--color-navy-950);
        font-weight: var(--font-bold);
        font-size: var(--text-sm);
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-lg);
        transition: opacity var(--transition-base);
        box-shadow: 0 8px 24px rgba(245, 158, 11, 0.2);
        margin-top: var(--space-2);
        cursor: pointer;
    }

    .form-submit:hover {
        opacity: 0.9;
    }
</style>
