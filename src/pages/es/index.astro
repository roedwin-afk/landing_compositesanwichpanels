---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/sections/Hero.astro";
import Finder from "../../components/sections/Finder.astro";
import Comparison from "../../components/sections/Comparison.astro";
import ScrollReveal from "../../components/ui/ScrollReveal.astro";
import { getLang, useTranslations } from "../../i18n/utils";

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);
---

<BaseLayout t={t} lang={lang}>
  <ScrollReveal />
  <main>
    <Hero t={t} lang={lang} />
    <Finder t={t} lang={lang} />
    <Comparison t={t} lang={lang} />
  </main>
</BaseLayout>
