---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import NavLinks from "../ui/NavLinks.astro";
import { Layers } from "lucide-astro";
import { Image } from "astro:assets";
import logo from "../../assets/logo.svg";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const base = import.meta.env.BASE_URL;
const prefix = lang === "es" ? `${base}es/` : base;
---

<footer class="footer">
  <div class="container">
    <!-- Top grid -->
    <div class="footer__grid">
      <!-- Brand col -->
      <div class="footer__brand">
        <a href={prefix} class="brand">
          <div class="brand__icon">
            <Layers size={18} />
          </div>
          <Image
                src={logo}
                alt="Panel sándwich para techo industrial"
                width={200}
                height={50}
                class="footer__logo-img"
                format="svg"
                quality={85}
                loading="eager"
            />
        </a>
        <p class="footer__desc">{t.footer.description}</p>
      </div>

      <!-- Domain col -->
      <div class="footer__col">
        <h4 class="footer__col-title">{t.footer.domain_label}</h4>
        <p class="footer__domain">{t.site.domain}</p>
        <p class="footer__domain-desc">{t.footer.domain_desc}</p>
      </div>

      <!-- Core Range col -->
      <div class="footer__col">
        <h4 class="footer__col-title">{t.footer.range_label}</h4>
        <ul class="footer__links">
          <li>
            <a href={`${prefix}#materials`} class="footer__link"
              >{t.footer.range_1}</a>
          </li>
          <li>
            <a href={`${prefix}#materials`} class="footer__link"
              >{t.footer.range_2}</a>
          </li>
          <li>
            <a href={`${prefix}#materials`} class="footer__link"
              >{t.footer.range_3}</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Nav links row -->
    <div class="footer__nav">
      <NavLinks t={t} lang={lang} orientation="horizontal" />
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p class="footer__copyright">{t.footer.copyright}</p>
      <p class="footer__compliance">{t.footer.compliance}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy-950);
    color: var(--color-slate-400);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-steel-900);
  }

  /* Top grid */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  /* Brand */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__logo-img {
    display: block;
    height: 3.5rem;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .brand__icon {
    background: linear-gradient(
      135deg,
      var(--color-navy-500),
      var(--color-amber-500)
    );
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .brand__name {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    letter-spacing: 0.08em;
    color: white;
  }

  .footer__desc {
    font-size: var(--text-xs);
    color: var(--color-slate-500);
    line-height: 1.7;
    font-weight: var(--font-light);
  }

  /* Columns */
  .footer__col {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__col-title {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: white;
  }

  .footer__domain {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-amber-500);
  }

  .footer__domain-desc {
    font-size: var(--text-xs);
    color: var(--color-slate-600);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__link {
    font-size: var(--text-xs);
    font-weight: var(--font-light);
    color: var(--color-slate-400);
    transition: color var(--transition-base);
  }

  .footer__link:hover {
    color: var(--color-amber-400);
  }

  /* Nav row */
  .footer__nav {
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-steel-900);
    border-bottom: 1px solid var(--color-steel-900);
    display: flex;
    justify-content: center;
  }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-block: var(--space-6);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__copyright,
  .footer__compliance {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-slate-600);
  }
</style>
