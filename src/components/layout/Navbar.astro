---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import NavLinks from "../ui/NavLinks.astro";
import MobileMenu from "./MobileMenu.astro";
import { Layers, Globe, MessageSquare } from "lucide-astro";
import { Image } from "astro:assets";
import logo from "../../assets/logo.svg";

interface Props {
    t: TranslationKeys;
    lang: Lang;
}

const { t, lang } = Astro.props;

const base = import.meta.env.BASE_URL;
const prefix = lang === "es" ? `${base}es/` : base;
const currentPath = Astro.url.pathname.replace(base, "").replace(/^es\//, "");

const alternateHref =
    lang === "en" ? `${base}es/${currentPath}` : `${base}${currentPath}`;

const alternateLabel = lang === "en" ? "ES" : "EN";
const alternateLang = lang === "en" ? "es" : "en";
---

<header class="navbar" id="navbar">
    <div class="container">
        <div class="navbar__inner">
            <!-- Brand -->
            <a href={prefix} class="navbar__brand">
                <div class="brand-icon">
                    <Layers size={24} />
                </div>
                <Image
                    src={logo}
                    alt="Panel sándwich para techo industrial"
                    width={200}
                    height={50}
                    class="navbar__logo-img"
                    format="svg"
                    quality={85}
                    loading="eager"
                />
            </a>

            <!-- Desktop Nav -->
            <nav class="navbar__nav" aria-label="Main navigation">
                <NavLinks t={t} lang={lang} orientation="horizontal" />
            </nav>

            <!-- Desktop Right Actions -->
            <div class="navbar__actions">
                <!-- <span class="navbar__domain">{t.site.domain}</span> -->

                <a
                    href={alternateHref}
                    class="lang-switcher"
                    lang={alternateLang}
                    aria-label={`Switch to ${alternateLabel}`}
                >
                    <Globe size={14} />
                    {alternateLabel}
                </a>

                <a
                    href={lang === "es"
                        ? `${base}es/contact`
                        : `${base}contact`}
                    class="navbar__cta"
                >
                    {t.nav.cta}
                    <MessageSquare size={14} />
                </a>

                <!-- Mobile Hamburger -->
                <button
                    id="mobile-toggle"
                    class="hamburger"
                    aria-label="Open menu"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                >
                    <span class="hamburger__line"></span>
                    <span class="hamburger__line"></span>
                    <span class="hamburger__line"></span>
                </button>
            </div>
        </div>
    </div>
</header>

<!-- Mobile Menu (drawer) -->
<MobileMenu t={t} lang={lang} />

<script>
    function initNavbar() {
        const navbar = document.getElementById("navbar");
        if (!navbar) return;

        const onScroll = () => {
            if (window.scrollY > 20) {
                navbar.classList.add("is-scrolled");
            } else {
                navbar.classList.remove("is-scrolled");
            }
        };

        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
    }

    initNavbar();
    document.addEventListener("astro:page-load", initNavbar);
</script>

<style>
    .navbar {
        position: sticky;
        top: 0;
        z-index: 50;
        background-color: rgba(20, 37, 57, 0.95);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-steel-800);
        color: white;
        transition: box-shadow var(--transition-slow);
    }

    .navbar.is-scrolled {
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    }

    .navbar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: var(--header-height);
        gap: var(--space-6);
    }

    /* Brand */
    .navbar__brand {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex-shrink: 0;
    }

    .navbar__logo-img {
        display: block;
        height: 3rem;
        width: auto;
        filter: brightness(0) invert(1);
    }

    .brand-icon {
        background: linear-gradient(
            135deg,
            var(--color-navy-500),
            var(--color-amber-500)
        );
        padding: var(--space-2);
        border-radius: var(--radius-md);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .brand-text {
        display: flex;
        flex-direction: column;
    }

    .brand-name {
        font-size: var(--text-base);
        font-weight: var(--font-bold);
        letter-spacing: 0.1em;
        line-height: 1;
        color: white;
    }

    .brand-sub {
        font-size: 0.6rem;
        font-family: var(--font-mono);
        color: var(--color-slate-400);
        letter-spacing: 0.15em;
        margin-top: 2px;
    }

    /* Desktop Nav */
    .navbar__nav {
        display: none;
        flex: 1;
        justify-content: center;
    }

    @media (min-width: 768px) {
        .navbar__nav {
            display: flex;
        }
    }

    /* Actions */
    .navbar__actions {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        flex-shrink: 0;
    }

    .navbar__domain {
        display: none;
        font-size: var(--text-xs);
        font-family: var(--font-mono);
        color: var(--color-slate-400);
    }

    @media (min-width: 1024px) {
        .navbar__domain {
            display: inline;
        }
    }

    .lang-switcher {
        display: none;
        align-items: center;
        gap: var(--space-1);
        font-size: var(--text-xs);
        font-weight: var(--font-semibold);
        font-family: var(--font-mono);
        color: var(--color-slate-300);
        padding: var(--space-1) var(--space-2);
        border: 1px solid var(--color-steel-700);
        border-radius: var(--radius-md);
        transition:
            color var(--transition-base),
            border-color var(--transition-base);
    }

    .lang-switcher:hover {
        color: var(--color-amber-500);
        border-color: var(--color-amber-500);
    }

    @media (min-width: 768px) {
        .lang-switcher {
            display: flex;
        }
    }

    .navbar__cta {
        display: none;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--text-sm);
        font-weight: var(--font-bold);
        color: var(--color-navy-950);
        background-color: var(--color-amber-500);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-md);
        transition: background-color var(--transition-base);
        white-space: nowrap;
    }

    .navbar__cta:hover {
        background-color: var(--color-amber-600);
    }

    @media (min-width: 768px) {
        .navbar__cta {
            display: flex;
        }
    }

    /* Hamburger */
    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        padding: var(--space-2);
        border-radius: var(--radius-md);
        transition: background-color var(--transition-base);
    }

    .hamburger:hover {
        background-color: rgba(255, 255, 255, 0.08);
    }

    .hamburger__line {
        display: block;
        width: 100%;
        height: 2px;
        background-color: var(--color-slate-300);
        border-radius: var(--radius-full);
        transition: background-color var(--transition-base);
    }

    .hamburger:hover .hamburger__line {
        background-color: white;
    }

    @media (min-width: 768px) {
        .hamburger {
            display: none;
        }
    }
</style>
