---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { TriangleAlert } from "lucide-astro";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t } = Astro.props;

const globalStandards = [
  {
    region: t.standards.europe_label,
    std: t.standards.europe_std,
    desc: t.standards.europe_desc,
  },
  {
    region: t.standards.us_label,
    std: t.standards.us_std,
    desc: t.standards.us_desc,
  },
  {
    region: t.standards.uk_label,
    std: t.standards.uk_std,
    desc: t.standards.uk_desc,
  },
  {
    region: t.standards.fm_label,
    std: t.standards.fm_std,
    desc: t.standards.fm_desc,
  },
];

const badges = [
  {
    key: "PUR",
    reaction: t.standards.pur_reaction,
    fireClass: t.standards.pur_class,
    badge: t.standards.pur_badge,
    variant: "warning" as const,
  },
  {
    key: "PIR",
    reaction: t.standards.pir_reaction,
    fireClass: t.standards.pir_class,
    badge: t.standards.pir_badge,
    variant: "success" as const,
  },
  {
    key: "RW",
    reaction: t.standards.rw_reaction,
    fireClass: t.standards.rw_class,
    badge: t.standards.rw_badge,
    variant: "danger" as const,
  },
];
---

<section id="standards" class="standards">
  <div class="container">

    <!-- Header -->
    <div class="standards__header reveal">
      <span class="section-label">{t.standards.label}</span>
      <h2 class="section-title">{t.standards.title}</h2>
      <p class="section-desc">{t.standards.description}</p>
    </div>

    <!-- Global Standards Grid -->
    <div class="standards__grid">
      {globalStandards.map((s, i) => (
        <div class:list={["std-card", "reveal", i > 0 && `reveal-delay-${i}`]}>
          <span class="std-card__region">{s.region}</span>
          <span class="std-card__code">{s.std}</span>
          <span class="std-card__desc">{s.desc}</span>
        </div>
      ))}
    </div>

    <!-- Material Safety Badges -->
    <div class="standards__badges reveal reveal-delay-2">
      {badges.map((b) => (
        <div class:list={["badge-row", `badge-row--${b.variant}`]}>
          <div class="badge-row__left">
            <span class:list={["badge-row__key", `badge-row__key--${b.variant}`]}>
              {b.key}
            </span>
            <div>
              <span class="badge-row__reaction">{b.reaction}</span>
              <span class="badge-row__class">{b.fireClass}</span>
            </div>
          </div>
          <span class:list={["badge-row__tag", `badge-row__tag--${b.variant}`]}>
            {b.badge}
          </span>
        </div>
      ))}
    </div>

    <!-- Warning Quote -->
    <div class="standards__warning reveal reveal-delay-3">
      <span class="warning__icon">
        <TriangleAlert size={32} />
      </span>
      <p class="warning__text">{t.standards.warning}</p>
    </div>

  </div>
</section>

<style>
  .standards {
    padding-block: var(--space-16);
    background-color: white;
  }

  /* Header */
  .standards__header {
    text-align: center;
    max-width: 48rem;
    margin-inline: auto;
    margin-bottom: var(--space-16);
  }

  .section-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-navy-500);
    margin-bottom: var(--space-2);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--color-navy-800);
    margin-bottom: var(--space-3);
  }

  .section-desc {
    font-size: var(--text-base);
    color: var(--color-slate-600);
    font-weight: var(--font-light);
    line-height: 1.7;
  }

  /* Standards grid */
  .standards__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .standards__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .std-card {
    background-color: var(--color-slate-50);
    border: 1px solid var(--color-slate-100);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .std-card:hover {
    border-color: rgba(245, 158, 11, 0.4);
    box-shadow: var(--shadow-md);
  }

  .std-card__region {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-slate-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .std-card__code {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-navy-800);
    line-height: 1.2;
  }

  .std-card__desc {
    font-size: 0.7rem;
    color: var(--color-slate-500);
    line-height: 1.5;
  }

  /* Safety badges */
  .standards__badges {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .badge-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4);
    border-radius: var(--radius-xl);
    border: 1px solid transparent;
    gap: var(--space-4);
  }

  .badge-row--warning {
    background-color: var(--color-slate-50);
    border-color: var(--color-slate-200);
  }

  .badge-row--success {
    background-color: rgba(11, 43, 74, 0.04);
    border-color: rgba(11, 43, 74, 0.1);
  }

  .badge-row--danger {
    background-color: rgba(239, 68, 68, 0.03);
    border-color: rgba(239, 68, 68, 0.1);
  }

  .badge-row__left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .badge-row__key {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    flex-shrink: 0;
  }

  .badge-row__key--warning {
    background-color: var(--color-slate-200);
    color: var(--color-slate-600);
  }

  .badge-row__key--success {
    background-color: var(--color-navy-800);
    color: white;
  }

  .badge-row__key--danger {
    background-color: var(--color-red-600);
    color: white;
  }

  .badge-row__reaction {
    display: block;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-slate-400);
  }

  .badge-row__class {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-slate-700);
  }

  .badge-row--success .badge-row__class {
    color: var(--color-navy-800);
  }

  .badge-row--danger .badge-row__class {
    color: var(--color-red-800);
  }

  .badge-row__tag {
    font-size: 0.65rem;
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .badge-row__tag--warning {
    background-color: #fee2e2;
    color: #991b1b;
  }

  .badge-row__tag--success {
    background-color: #dcfce7;
    color: #166534;
  }

  .badge-row__tag--danger {
    background-color: #fee2e2;
    color: #991b1b;
  }

  /* Warning quote */
  .standards__warning {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-6);
    background-color: var(--color-slate-50);
    border-left: 4px solid var(--color-amber-500);
    border-radius: var(--radius-2xl);
    max-width: 56rem;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .standards__warning {
      align-items: center;
    }
  }

  .warning__icon {
    color: var(--color-amber-500);
    flex-shrink: 0;
  }

  .warning__text {
    font-size: var(--text-sm);
    font-style: italic;
    font-weight: var(--font-light);
    color: var(--color-slate-600);
    line-height: 1.7;
  }
</style>