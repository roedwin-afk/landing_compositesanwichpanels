---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t } = Astro.props;

const rows = [
  {
    label: t.comparison.row1_label,
    sub: t.comparison.row1_sub,
    pur: { value: t.comparison.row1_pur },
    pir: { value: t.comparison.row1_pir, note: t.comparison.row1_pir_note },
    rw:  { value: t.comparison.row1_rw },
  },
  {
    label: t.comparison.row2_label,
    sub: t.comparison.row2_sub,
    pur: { value: t.comparison.row2_pur },
    pir: { value: t.comparison.row2_pir },
    rw:  { value: t.comparison.row2_rw, note: t.comparison.row2_rw_note, highlight: true },
  },
  {
    label: t.comparison.row3_label,
    sub: t.comparison.row3_sub,
    pur: { value: t.comparison.row3_pur },
    pir: { value: t.comparison.row3_pir },
    rw:  { value: t.comparison.row3_rw, note: t.comparison.row3_rw_note, highlight: true },
  },
  {
    label: t.comparison.row4_label,
    sub: t.comparison.row4_sub,
    pur: { value: t.comparison.row4_pur },
    pir: { value: t.comparison.row4_pir, strong: true },
    rw:  { value: t.comparison.row4_rw },
  },
  {
    label: t.comparison.row5_label,
    sub: t.comparison.row5_sub,
    pur: { value: t.comparison.row5_pur },
    pir: { value: t.comparison.row5_pir },
    rw:  { value: t.comparison.row5_rw, note: t.comparison.row5_rw_note },
  },
  {
    label: t.comparison.row6_label,
    sub: t.comparison.row6_sub,
    pur: { value: t.comparison.row6_pur, small: true },
    pir: { value: t.comparison.row6_pir, small: true, strong: true },
    rw:  { value: t.comparison.row6_rw,  small: true },
  },
];
---

<section id="comparison" class="comparison">
  <div class="container">

    <!-- Header -->
    <div class="comparison__header reveal">
      <span class="section-label">{t.comparison.label}</span>
      <h2 class="section-title">{t.comparison.title}</h2>
      <p class="section-desc">{t.comparison.description}</p>
    </div>

    <!-- Mobile swipe hint -->
    <div class="swipe-hint reveal">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
      </svg>
      <span>{t.comparison.swipe_hint}</span>
    </div>

    <!-- Table wrapper -->
    <div class="table-wrapper reveal reveal-delay-1">
      <table class="comparison-table">
        <thead>
          <tr>
            <th class="col-metric">{t.comparison.col_metric}</th>
            <th class="col-pur">
              <span class="th-label">PUR</span>
              <span class="th-sub">{t.comparison.col_pur}</span>
            </th>
            <th class="col-pir">
              <span class="th-label th-label--pir">PIR</span>
              <span class="th-sub">{t.comparison.col_pir}</span>
            </th>
            <th class="col-rw">
              <span class="th-label">RW</span>
              <span class="th-sub">{t.comparison.col_rw}</span>
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class:list={["table-row", i % 2 !== 0 && "table-row--alt"]}>
              <!-- Metric label -->
              <td class="cell-metric">
                <span class="metric-label">{row.label}</span>
                <span class="metric-sub">{row.sub}</span>
              </td>

              <!-- PUR -->
              <td class="cell-value">
                <span class:list={["cell-text", row.pur.small && "cell-text--small"]}>
                  {row.pur.value}
                </span>
              </td>

              <!-- PIR (highlighted column) -->
              <td class="cell-value cell-value--pir">
                <span class:list={[
                  "cell-text",
                  row.pir.small  && "cell-text--small",
                  row.pir.strong && "cell-text--strong",
                ]}>
                  {row.pir.value}
                </span>
                {row.pir.note && (
                  <span class="cell-note cell-note--green">{row.pir.note}</span>
                )}
              </td>

              <!-- Rockwool -->
              <td class="cell-value">
                <span class:list={[
                  "cell-text",
                  row.rw.small     && "cell-text--small",
                  row.rw.highlight && "cell-text--highlight",
                ]}>
                  {row.rw.value}
                </span>
                {row.rw.note && (
                  <span class="cell-note cell-note--muted">{row.rw.note}</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Footnote -->
    <p class="comparison__footnote reveal reveal-delay-2">
      {t.comparison.footnote}
    </p>

  </div>
</section>

<style>
  .comparison {
    padding-block: var(--space-16);
    background-color: white;
  }

  /* Header */
  .comparison__header {
    text-align: center;
    max-width: 48rem;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-navy-500);
    margin-bottom: var(--space-2);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--color-navy-800);
    margin-bottom: var(--space-3);
  }

  .section-desc {
    font-size: var(--text-base);
    color: var(--color-slate-600);
    font-weight: var(--font-light);
    line-height: 1.7;
  }

  /* Swipe hint — mobile only */
  .swipe-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--color-slate-400);
    background-color: var(--color-slate-50);
    border: 1px solid var(--color-slate-100);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-4);
    margin-bottom: var(--space-3);
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @media (min-width: 1024px) {
    .swipe-hint {
      display: none;
    }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  /* Table wrapper */
  .table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-slate-200);
    box-shadow: var(--shadow-md);
  }

  /* Table */
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 700px;
  }

  /* Head */
  .comparison-table thead tr {
    background-color: var(--color-navy-950);
    color: white;
  }

  .comparison-table th {
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-right: 1px solid var(--color-steel-800);
    vertical-align: middle;
  }

  .comparison-table th:last-child {
    border-right: none;
  }

  .col-metric {
    text-align: left;
    position: sticky;
    left: 0;
    background-color: var(--color-navy-950);
    min-width: 180px;
  }

  .col-pur,
  .col-pir,
  .col-rw {
    text-align: center;
  }

  .col-pir {
    background-color: var(--color-navy-900);
  }

  .th-label {
    display: block;
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-1);
  }

  .th-label--pir {
    color: var(--color-amber-400);
  }

  .th-sub {
    display: block;
    font-size: 0.65rem;
    font-weight: var(--font-normal);
    color: var(--color-slate-400);
    text-transform: none;
    letter-spacing: 0;
  }

  /* Body rows */
  .table-row {
    border-bottom: 1px solid var(--color-slate-100);
    transition: background-color var(--transition-fast);
  }

  .table-row:hover {
    background-color: rgba(248, 250, 252, 0.8);
  }

  .table-row--alt {
    background-color: rgba(248, 250, 252, 0.4);
  }

  .table-row--alt:hover {
    background-color: rgba(241, 245, 249, 0.8);
  }

  /* Cells */
  .cell-metric {
    padding: var(--space-4) var(--space-6);
    position: sticky;
    left: 0;
    background-color: white;
    border-right: 1px solid var(--color-slate-200);
  }

  .table-row--alt .cell-metric {
    background-color: rgba(248, 250, 252, 0.4);
  }

  .table-row:hover .cell-metric {
    background-color: rgba(248, 250, 252, 0.8);
  }

  .metric-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-slate-700);
  }

  .metric-sub {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-slate-400);
    font-weight: var(--font-normal);
    margin-top: 2px;
  }

  .cell-value {
    padding: var(--space-4) var(--space-6);
    text-align: center;
    border-right: 1px solid var(--color-slate-200);
    vertical-align: middle;
  }

  .cell-value:last-child {
    border-right: none;
  }

  .cell-value--pir {
    background-color: rgba(11, 43, 74, 0.03);
  }

  .cell-text {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-slate-600);
  }

  .cell-text--small {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    line-height: 1.5;
  }

  .cell-text--strong {
    font-weight: var(--font-semibold);
    color: var(--color-navy-800);
  }

  .cell-text--highlight {
    font-weight: var(--font-semibold);
    color: var(--color-red-600);
  }

  .cell-note {
    display: block;
    font-size: var(--text-xs);
    margin-top: var(--space-1);
  }

  .cell-note--green {
    color: var(--color-green-600);
  }

  .cell-note--muted {
    color: var(--color-slate-500);
    font-family: var(--font-sans);
  }

  /* Footnote */
  .comparison__footnote {
    font-size: var(--text-xs);
    color: var(--color-slate-500);
    font-family: var(--font-mono);
    line-height: 1.6;
    margin-top: var(--space-4);
  }
</style>