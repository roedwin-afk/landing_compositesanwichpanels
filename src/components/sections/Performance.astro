---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { Lightbulb } from "lucide-astro";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t } = Astro.props;
---

<section id="performance" class="performance technical-grid">
  <div class="performance__radial"></div>
  <div class="container">
    <div class="performance__grid">

      <!-- Left: Info -->
      <div class="performance__info">
        <span class="section-label reveal">{t.performance.label}</span>
        <h2 class="section-title reveal reveal-delay-1">{t.performance.title}</h2>
        <p class="section-desc reveal reveal-delay-2">{t.performance.description}</p>

        <div class="insight-box reveal reveal-delay-3">
          <div class="insight-box__header">
            <Lightbulb size={20} class="insight-box__icon" />
            <span class="insight-box__label">{t.performance.insight_label}</span>
          </div>
          <p class="insight-box__text">{t.performance.insight_text}</p>
        </div>

        <!-- Legend -->
        <div class="chart-legend reveal reveal-delay-4">
          <div class="legend-item">
            <span class="legend-line legend-line--pur"></span>
            <span>{t.performance.legend_pur}</span>
          </div>
          <div class="legend-item">
            <span class="legend-line legend-line--pir"></span>
            <span>{t.performance.legend_pir}</span>
          </div>
          <div class="legend-item">
            <span class="legend-line legend-line--rw"></span>
            <span>{t.performance.legend_rw}</span>
          </div>
        </div>
      </div>

      <!-- Right: Chart -->
      <div class="performance__chart-wrap reveal reveal-delay-2">
        <div class="chart-card">
          <span class="chart-card__label">{t.performance.chart_label}</span>
          <div class="chart-container">
            <canvas id="thermalChart"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import Chart from "chart.js/auto";

  function initChart() {
    const canvas = document.getElementById("thermalChart") as HTMLCanvasElement | null;
    if (!canvas) return;

    // Destroy previous instance if exists (View Transitions)
    const existing = Chart.getChart(canvas);
    if (existing) existing.destroy();

    const temperatures = [0, 10, 20, 30, 40, 50, 60, 75, 90, 105, 120];
    const lambdaPUR = [0.021, 0.022, 0.023, 0.0245, 0.026, 0.028, 0.0305, 0.035, 0.041, 0.049, 0.061];
    const lambdaPIR = [0.0195, 0.020, 0.021, 0.022, 0.0235, 0.025, 0.027, 0.030, 0.0345, 0.040, 0.0475];
    const lambdaRW  = [0.034, 0.035, 0.036, 0.037, 0.038, 0.039, 0.040, 0.0415, 0.043, 0.0445, 0.046];

    new Chart(canvas, {
      type: "line",
      data: {
        labels: temperatures.map((t) => `${t}°C`),
        datasets: [
          {
            label: "PUR",
            data: lambdaPUR,
            borderColor: "#F59E0B",
            backgroundColor: "transparent",
            borderWidth: 2,
            tension: 0.3,
            pointRadius: 3,
            pointHoverRadius: 6,
          },
          {
            label: "PIR",
            data: lambdaPIR,
            borderColor: "#D97706",
            backgroundColor: "transparent",
            borderWidth: 3,
            tension: 0.3,
            pointRadius: 4,
            pointHoverRadius: 7,
          },
          {
            label: "Rockwool",
            data: lambdaRW,
            borderColor: "#EF4444",
            backgroundColor: "transparent",
            borderWidth: 2,
            tension: 0.2,
            pointRadius: 3,
            pointHoverRadius: 6,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            title: {
              display: true,
              text: "Lambda λ (W/m·K)",
              color: "#94A3B8",
              font: { family: "JetBrains Mono", size: 10 },
            },
            grid:  { color: "rgba(74, 106, 138, 0.15)" },
            ticks: {
              color: "#94A3B8",
              font: { family: "JetBrains Mono", size: 10 },
            },
          },
          x: {
            title: {
              display: true,
              text: "Core Environmental Temp (°C)",
              color: "#94A3B8",
              font: { family: "JetBrains Mono", size: 10 },
            },
            grid:  { color: "rgba(74, 106, 138, 0.15)" },
            ticks: {
              color: "#94A3B8",
              font: { family: "JetBrains Mono", size: 10 },
            },
          },
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: "#0F172A",
            titleFont: { family: "Inter", size: 11 },
            bodyFont:  { family: "JetBrains Mono", size: 11 },
            callbacks: {
              label: (ctx) => ` ${ctx.dataset.label}: ${ctx.raw} W/m·K`,
            },
          },
        },
      },
    });
  }

  initChart();
  document.addEventListener("astro:page-load", initChart);
</script>

<style>
  .performance {
    position: relative;
    padding-block: var(--space-16);
    background: linear-gradient(to right, var(--color-navy-950), var(--color-navy-900));
    color: white;
    overflow: hidden;
  }

  .performance__radial {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(20, 37, 57, 0.9),
      rgba(10, 18, 30, 0.95)
    );
    pointer-events: none;
  }

  .performance__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .performance__grid {
      grid-template-columns: 5fr 7fr;
    }
  }

  /* Info column */
  .performance__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .section-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-amber-400);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: white;
    line-height: 1.2;
  }

  .section-desc {
    font-size: var(--text-sm);
    color: var(--color-slate-300);
    font-weight: var(--font-light);
    line-height: 1.7;
  }

  /* Insight box */
  .insight-box {
    background-color: rgba(20, 37, 57, 0.6);
    border: 1px solid var(--color-steel-800);
    border-radius: var(--radius-xl);
    padding: var(--space-4);
  }

  .insight-box__header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .insight-box__icon {
    color: var(--color-amber-400);
    flex-shrink: 0;
  }

  .insight-box__label {
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    color: var(--color-amber-400);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }

  .insight-box__text {
    font-size: var(--text-xs);
    color: var(--color-slate-400);
    line-height: 1.6;
  }

  /* Legend */
  .chart-legend {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--color-slate-300);
  }

  .legend-line {
    display: inline-block;
    width: 1.5rem;
    height: 2px;
    border-radius: var(--radius-full);
  }

  .legend-line--pur { background-color: #F59E0B; }
  .legend-line--pir { background-color: #D97706; }
  .legend-line--rw  { background-color: #EF4444; }

  /* Chart card */
  .performance__chart-wrap {
    width: 100%;
  }

  .chart-card {
    background-color: rgba(20, 37, 57, 0.4);
    border: 1px solid var(--color-steel-800);
    border-radius: var(--radius-2xl);
    padding: var(--space-6);
    backdrop-filter: blur(8px);
  }

  .chart-card__label {
    display: block;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--color-slate-400);
    margin-bottom: var(--space-4);
  }

  .chart-container {
    position: relative;
    height: 18rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .chart-container {
      height: 24rem;
    }
  }
</style>