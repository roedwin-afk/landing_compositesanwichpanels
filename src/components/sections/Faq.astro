---
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { ChevronDown } from "lucide-astro";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t } = Astro.props;
---

<section id="faq" class="faq">
  <div class="container">

    <!-- Header -->
    <div class="faq__header reveal">
      <span class="section-label">{t.faq.label}</span>
      <h2 class="section-title">{t.faq.title}</h2>
      <p class="section-desc">{t.faq.description}</p>
    </div>

    <!-- Accordion -->
    <div class="faq__list" id="faq-list">
      {t.faq.items.map((item, i) => (
        <div
          class:list={["faq-item", "reveal", i > 0 && `reveal-delay-${Math.min(i, 4)}`]}
          data-index={i}
        >
          <button
            class="faq-item__trigger"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
            id={`faq-trigger-${i}`}
          >
            <span class="faq-item__question">{item.q}</span>
            <span class="faq-item__icon" aria-hidden="true">
              <ChevronDown size={20} />
            </span>
          </button>
          <div
            class="faq-item__body"
            id={`faq-answer-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
          >
            <p class="faq-item__answer">{item.a}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  function initFaq() {
    const triggers = document.querySelectorAll<HTMLButtonElement>(".faq-item__trigger");
    if (!triggers.length) return;

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const isOpen = trigger.getAttribute("aria-expanded") === "true";
        const body = trigger.nextElementSibling as HTMLElement;

        // Close all
        triggers.forEach((t) => {
          t.setAttribute("aria-expanded", "false");
          const b = t.nextElementSibling as HTMLElement;
          if (b) b.style.maxHeight = "0px";
          t.closest(".faq-item")?.classList.remove("is-open");
        });

        // Open clicked if it was closed
        if (!isOpen) {
          trigger.setAttribute("aria-expanded", "true");
          trigger.closest(".faq-item")?.classList.add("is-open");
          if (body) body.style.maxHeight = body.scrollHeight + "px";
        }
      });
    });

    // Open first item by default
    const first = triggers[0];
    if (first) {
      first.setAttribute("aria-expanded", "true");
      first.closest(".faq-item")?.classList.add("is-open");
      const body = first.nextElementSibling as HTMLElement;
      if (body) body.style.maxHeight = body.scrollHeight + "px";
    }
  }

  initFaq();
  document.addEventListener("astro:page-load", initFaq);
</script>

<style>
  .faq {
    padding-block: var(--space-16);
    background-color: var(--color-slate-50);
    border-top: 1px solid var(--color-slate-200);
  }

  /* Header */
  .faq__header {
    text-align: center;
    max-width: 48rem;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .section-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-navy-500);
    margin-bottom: var(--space-2);
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--color-navy-800);
    margin-bottom: var(--space-3);
  }

  .section-desc {
    font-size: var(--text-base);
    color: var(--color-slate-600);
    font-weight: var(--font-light);
    line-height: 1.7;
  }

  /* Accordion list */
  .faq__list {
    max-width: 52rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Item */
  .faq-item {
    background-color: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .faq-item:hover {
    border-color: var(--color-slate-300);
  }

  .faq-item.is-open {
    border-color: var(--color-amber-500);
    box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.08);
  }

  /* Trigger */
  .faq-item__trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    text-align: left;
    background: none;
    cursor: pointer;
  }

  .faq-item__question {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-navy-800);
    line-height: 1.5;
    flex: 1;
  }

  .faq-item.is-open .faq-item__question {
    color: var(--color-navy-900);
  }

  /* Chevron icon */
  .faq-item__icon {
    color: var(--color-slate-400);
    flex-shrink: 0;
    transition: transform var(--transition-base), color var(--transition-base);
  }

  .faq-item.is-open .faq-item__icon {
    transform: rotate(180deg);
    color: var(--color-amber-500);
  }

  /* Body */
  .faq-item__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .faq-item__answer {
    padding: 0 var(--space-6) var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-slate-600);
    line-height: 1.75;
    border-top: 1px solid var(--color-slate-100);
    padding-top: var(--space-4);
  }
</style>